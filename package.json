{
  "name": "skills-desktop",
  "version": "0.7.1",
  "description": "Visualize installed Skills and symlink status across AI agents",
  "main": "./out/main/index.mjs",
  "author": "Laststance.io",
  "homepage": "https://github.com/laststance/skills-desktop",
  "license": "MIT",
  "packageManager": "pnpm@10.29.3",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev --remote-debugging-port=9222",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "prettier": "prettier --ignore-unknown --write .",
    "clean": "rm -rf dist build .vite node_modules pnpm-lock.yaml"
  },
  "dependencies": {
    "@laststance/redux-storage-middleware": "^0.2.1",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@reduxjs/toolkit": "^2.11.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "lucide-react": "^1.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.2.0",
    "react-resizable-panels": "^4.8.0",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@aspect-ratio/core": "^1.0.0",
    "@electron/notarize": "^3.1.1",
    "@laststance/react-next-eslint-plugin": "^2.2.0",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "code-inspector-plugin": "^1.4.5",
    "electron": "^41.1.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "eslint": "^10.1.0",
    "eslint-config-ts-prefixer": "^4.2.0",
    "eslint-plugin-react-you-might-not-need-an-effect": "^0.9.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.2.2",
    "typescript": "^6.0.2",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
