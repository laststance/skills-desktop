{
  "name": "skills-desktop",
  "version": "0.27.3",
  "description": "Visualize installed Skills and symlink status across AI agents",
  "main": "./out/main/index.mjs",
  "author": "Laststance.io",
  "homepage": "https://github.com/laststance/skills-desktop",
  "license": "MIT",
  "packageManager": "pnpm@11.5.1+sha512.93f7b57422ea7068257235b4c16eb60762eb68e1dc23723199cc739043ea9be2c4143274a399d8c6defa2b1176226d9ca1c4b63482d6200c1a8fbaa78c1d1485",
  "scripts": {
    "dev": "ELECTRON_RUN_AS_NODE= electron-vite dev --remote-debugging-port=9222",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "build:mac": "electron-vite build && electron-builder --mac",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "build:e2e": "E2E_BUILD=1 electron-vite build",
    "test:e2e": "pnpm build:e2e && playwright test --config=e2e/playwright.config.ts",
    "test:e2e:headed": "pnpm build:e2e && playwright test --config=e2e/playwright.config.ts --headed",
    "test:release:macos-window": "node scripts/verify-macos-window-rendering.mjs",
    "gen:e2e-snapshot": "E2E_GEN_SNAPSHOT=1 pnpm test:e2e",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "fallow:dead-code": "pnpm exec fallow dead-code --fail-on-issues",
    "fallow:dupes": "pnpm exec fallow dupes --fail-on-issues",
    "fallow:health": "pnpm exec fallow health --complexity --fail-on-issues",
    "validate": "run-p lint test typecheck fallow:dead-code fallow:dupes fallow:health storybook:build",
    "prepare": "husky",
    "prettier": "prettier --ignore-unknown --write .",
    "clean": "rm -rf dist build .vite node_modules pnpm-lock.yaml"
  },
  "dependencies": {
    "@laststance/redux-storage-middleware": "^0.3.2",
    "@radix-ui/react-checkbox": "^1.3.7",
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-dropdown-menu": "^2.1.20",
    "@radix-ui/react-scroll-area": "^1.2.14",
    "@radix-ui/react-separator": "^1.1.11",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-toggle-group": "^1.1.15",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@reduxjs/toolkit": "^2.12.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.9",
    "lucide-react": "^1.25.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-grid-layout": "^2.2.3",
    "react-markdown": "^10.1.0",
    "react-redux": "^9.3.0",
    "react-resizable-panels": "^4.12.2",
    "react-window": "^2.2.7",
    "remark-gfm": "^4.0.1",
    "shiki": "^4.3.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "ts-pattern": "^5.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@electron/notarize": "^3.1.1",
    "@laststance/react-next-eslint-plugin": "^2.3.0",
    "@playwright/test": "^1.61.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@storybook/addon-a11y": "10.5.0",
    "@storybook/addon-docs": "10.5.0",
    "@storybook/react-vite": "10.5.0",
    "@tailwindcss/vite": "^4.3.2",
    "@types/culori": "^4.0.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/browser-playwright": "^4.1.10",
    "@vitest/coverage-v8": "^4.1.10",
    "babel-plugin-react-compiler": "^1.0.0",
    "code-inspector-plugin": "~2.0.1",
    "culori": "^4.0.2",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "electron-devtools-installer": "^4.0.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.7.0",
    "eslint-config-ts-prefixer": "^4.2.1",
    "eslint-import-resolver-typescript": "4.4.5",
    "eslint-plugin-import-x": "4.17.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "^1.0.1",
    "fallow": "3.5.1",
    "happy-dom": "^20.10.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.8",
    "npm-run-all2": "^9.0.2",
    "playwright": "^1.61.1",
    "prettier": "^3.9.5",
    "sharp": "^0.35.3",
    "storybook": "10.5.0",
    "tailwindcss": "^4.3.2",
    "typescript": "6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "lint-staged": {
    "*": "prettier --ignore-unknown --write"
  }
}
